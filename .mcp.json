{
  "name": "personal-finance-ai-mcp",
  "description": "Personal Finance Ai automation via MCP. Includes track budget, calculate savings, plan debt payoff. By MEOK AI Labs.",
  "version": "1.0.0",
  "tools": [
    {
      "name": "track_budget",
      "description": "Analyze spending against recommended budget allocations.",
      "parameters": {
        "type": "object",
        "properties": {
          "monthly_income": {
            "type": "number"
          },
          "expenses": {
            "type": "array"
          }
        },
        "required": [
          "monthly_income",
          "expenses"
        ]
      }
    },
    {
      "name": "calculate_savings",
      "description": "Calculate time to reach a savings goal with compound interest.",
      "parameters": {
        "type": "object",
        "properties": {
          "target_amount": {
            "type": "number"
          },
          "current_savings": {
            "type": "number"
          },
          "monthly_contribution": {
            "type": "number"
          },
          "annual_return_pct": {
            "type": "number"
          },
          "inflation_pct": {
            "type": "number"
          }
        },
        "required": [
          "target_amount"
        ]
      }
    },
    {
      "name": "plan_debt_payoff",
      "description": "Create a debt payoff plan using avalanche or snowball method.",
      "parameters": {
        "type": "object",
        "properties": {
          "debts": {
            "type": "array"
          },
          "extra_monthly_payment": {
            "type": "number"
          },
          "strategy": {
            "type": "string"
          }
        },
        "required": [
          "debts"
        ]
      }
    },
    {
      "name": "analyze_investment",
      "description": "Analyze investment growth with asset allocation modeling.",
      "parameters": {
        "type": "object",
        "properties": {
          "initial_investment": {
            "type": "number"
          },
          "monthly_addition": {
            "type": "number"
          },
          "years": {
            "type": "integer"
          },
          "allocation": {
            "type": "object"
          }
        },
        "required": [
          "initial_investment"
        ]
      }
    },
    {
      "name": "estimate_tax",
      "description": "Estimate US federal income tax liability.",
      "parameters": {
        "type": "object",
        "properties": {
          "gross_income": {
            "type": "number"
          },
          "filing_status": {
            "type": "string"
          },
          "deductions": {
            "type": "object"
          },
          "state": {
            "type": "string"
          },
          "self_employment_income": {
            "type": "number"
          }
        },
        "required": [
          "gross_income"
        ]
      }
    }
  ]
}